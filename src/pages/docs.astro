---
import Default from "../layouts/Default.astro";

const modules = import.meta.glob("../../public/docs/**/*.md", {
    eager: true,
    import: "default",
    query: "?raw",
});

const docs = Object.keys(modules)
    .map((path) => {
        const slug = path
            .replace("../../public/docs/", "")
            .replace(/\.md$/, "");
        const name = slug.split("/").at(-1) ?? slug;

        return {
            name,
            slug,
            href: `/docs/${slug}`,
        };
    })
    .sort((a, b) => a.name.localeCompare(b.name));
---

<Default>
    <style slot="styles">
        .docs-title {
            font-size: clamp(3rem, 8vw, 6rem);
            line-height: 0.9;
        }

        .doc-card:hover {
            background: #f0e000;
        }

        .doc-card:hover .doc-index {
            background: #000;
            color: #f0e000;
        }
    </style>

    <main class="border-b-4 border-black">
        <section
            class="grid grid-cols-1 lg:grid-cols-[320px_1fr] min-h-[calc(100vh-8rem)]"
        >
            <div
                class="flex flex-col justify-between gap-10 bg-black text-[#f5f0e8] px-6 py-8 sm:px-8 lg:border-r-4 border-black"
            >
                <div class="flex flex-col gap-5">
                    <span
                        class="text-[0.65rem] tracking-[0.22em] uppercase text-[#f0e000]"
                    >
                        Generated API Docs
                    </span>
                    <h1
                        class="docs-title m-0 tracking-[0.04em]"
                        style="font-family:'Bebas Neue',sans-serif;"
                    >
                        Docs
                    </h1>
                    <p class="m-0 text-[0.75rem] leading-[1.7] opacity-65 max-w-[38ch]">
                        Built from the Markdown files generated in
                        public/docs before the Astro app is built.
                    </p>
                </div>

                <span class="text-[0.65rem] tracking-[0.18em] uppercase opacity-50">
                    {docs.length} modules
                </span>
            </div>

            <div class="bg-[#f5f0e8]">
                <div
                    class="grid border-b-4 border-black bg-[#f0e000]"
                    style="grid-template-columns: 56px 1fr;"
                >
                    <div
                        class="grid place-items-center border-r-4 border-black py-3 text-[0.75rem] tracking-[0.16em]"
                        style="font-family:'Bebas Neue',sans-serif;"
                    >
                        #
                    </div>
                    <div
                        class="flex items-center px-5 py-3 text-[0.75rem] tracking-[0.16em]"
                        style="font-family:'Bebas Neue',sans-serif;"
                    >
                        Module
                    </div>
                </div>

                {docs.length === 0 && (
                    <div class="px-6 py-16 opacity-50">
                        No generated docs found.
                    </div>
                )}

                {docs.map((doc, i) => (
                    <a
                        href={doc.href}
                        class="doc-card grid no-underline text-black border-b-4 border-black transition-colors duration-[150ms]"
                        style="grid-template-columns: 56px 1fr auto;"
                    >
                        <span
                            class="doc-index grid place-items-center border-r-4 border-black bg-[#f5f0e8] py-5 transition-colors duration-[150ms]"
                            style="font-family:'Bebas Neue',sans-serif; font-size:1.35rem;"
                        >
                            {(i + 1).toString().padStart(2, "0")}
                        </span>
                        <span class="flex flex-col gap-1 min-w-0 px-5 py-4">
                            <span
                                class="tracking-[0.06em]"
                                style="font-family:'Bebas Neue',sans-serif; font-size:1.8rem;"
                            >
                                {doc.name}
                            </span>
                            <span class="text-[0.65rem] opacity-50 break-all">
                                {doc.href}
                            </span>
                        </span>
                        <span
                            class="hidden sm:grid place-items-center px-6 text-3xl"
                            style="font-family:'Bebas Neue',sans-serif;"
                        >
                            -&gt;
                        </span>
                    </a>
                ))}
            </div>
        </section>
    </main>
</Default>
