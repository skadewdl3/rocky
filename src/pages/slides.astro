---
import Default from "../layouts/Default.astro";

export const prerender = false;

const protocol = Astro.url.protocol;
const host = `${protocol}//${Astro.url.host.split("/").filter(Boolean).join("/")}`;

let slides: Record<
    string,
    { title: string; description: string; date?: string; video?: string }
> = {};

try {
    const res = await fetch(new URL("/slides.json", Astro.url));
    slides = await res.json();
} catch (e) {
    // fallback: empty
}

const entries = Object.entries(slides).map(([slug, meta]) => ({
    slug,
    href: `${host}${slug}.pdf`,
    ...meta,
}));
---

<Default>
    <style slot="styles">
        /* clamp() font size — no Tailwind equivalent */
        .card-title {
            font-size: clamp(1.1rem, 4vw, 1.6rem);
            line-height: 1;
        }
        .empty-label {
            font-size: clamp(1.5rem, 6vw, 2.5rem);
        }

        /* hover-child selectors — Tailwind can't target children on parent hover */
        .slide-card:hover                { background: #f0e000; }
        .slide-card:hover .card-index   { background: #000; color: #f0e000; }
        .slide-card:hover .card-arrow   { opacity: 1; transform: translateX(0); }

        /* arrow starts hidden/offset */
        .card-arrow {
            opacity: 0;
            transform: translateX(-6px);
            transition: opacity 0.15s, transform 0.15s;
        }

        /* mobile: inline arrow via ::after pseudo */
        @media (max-width: 520px) {
            .card-title::after {
                content: " →";
                opacity: 0.4;
            }
        }
    </style>

    <main class="grid grid-cols-1">
        <section class="flex flex-col">

            <!-- Column header bar -->
            <div class="grid border-b-4 border-black bg-black text-[#f0e000]"
                 style="grid-template-columns: 60px 1fr;">
                <!-- on mobile shrink to 48px -->
                <div class="flex items-center justify-center px-3 py-2 border-r-4 border-[#f0e000] min-w-[48px] sm:min-w-[60px]">
                    <span class="tracking-[0.15em]" style="font-family:'Bebas Neue',sans-serif; font-size:0.85rem;">#</span>
                </div>
                <div class="flex items-center px-4 sm:px-6 py-2">
                    <span class="tracking-[0.15em]" style="font-family:'Bebas Neue',sans-serif; font-size:0.85rem;">Title / Description</span>
                </div>
            </div>

            <!-- Empty state -->
            {entries.length === 0 && (
                <div class="flex items-center justify-center flex-1 px-6 py-24 opacity-30">
                    <span class="empty-label tracking-[0.15em]" style="font-family:'Bebas Neue',sans-serif;">
                        No slides found
                    </span>
                </div>
            )}

            <!-- Slide cards -->
            {entries.map((entry, i) => (
                <div
                    class="slide-card grid border-b-4 border-black cursor-pointer transition-colors duration-[150ms]"
                    style="grid-template-columns: 48px 1fr auto;"
                    data-url={entry.href}
                >
                    <!-- Index -->
                    <div
                        class="card-index flex items-center justify-center border-r-4 border-black bg-[#f5f0e8] py-5 tracking-[0.05em] transition-colors duration-[150ms] min-w-[48px] sm:min-w-[60px] text-lg sm:text-2xl"
                        style="font-family:'Bebas Neue',sans-serif;"
                    >
                        {(i + 1).toString().padStart(2, "0")}
                    </div>

                    <!-- Body -->
                    <div class="flex flex-col gap-[0.35rem] min-w-0 px-4 py-4 sm:px-6 sm:py-5">
                        <div
                            class="card-title tracking-[0.06em]"
                            style="font-family:'Bebas Neue',sans-serif;"
                        >{entry.title}</div>

                        {entry.description && (
                            <div
                                class="text-[0.68rem] leading-[1.55] opacity-60 max-w-[56ch] break-words"
                                style="font-family:'Space Mono',monospace;"
                            >{entry.description}</div>
                        )}

                        <div class="flex flex-wrap gap-2 mt-1">
                            <span class="text-[0.6rem] font-bold tracking-[0.18em] uppercase border-2 border-black px-[7px] py-[2px] opacity-55 whitespace-nowrap"
                                  style="font-family:'Space Mono',monospace;">PDF</span>
                            {entry.date && (
                                <span class="text-[0.6rem] font-bold tracking-[0.18em] uppercase border-2 border-black px-[7px] py-[2px] opacity-55 whitespace-nowrap"
                                      style="font-family:'Space Mono',monospace;">{entry.date}</span>
                            )}
                            {entry.video && (
                                <span
                                    class="badge-video text-[0.6rem] font-bold tracking-[0.18em] uppercase bg-black text-[#f0e000] border-2 border-black px-[7px] py-[2px] whitespace-nowrap cursor-pointer"
                                    style="font-family:'Space Mono',monospace;"
                                    data-url={entry.video}
                                >▶ Video</span>
                            )}
                        </div>
                    </div>

                    <!-- Arrow (hidden on mobile via parent grid shrinking) -->
                    <div class="hidden sm:flex items-center px-6">
                        <span class="card-arrow" style="font-family:'Bebas Neue',sans-serif; font-size:2rem;">→</span>
                    </div>
                </div>
            ))}

        </section>
    </main>

    <!-- Ticker -->
    <div slot="footer" class="border-t-4 border-b-4 border-black overflow-hidden py-2 bg-[#f0e000]">
        <div class="ticker-inner">
            {[...entries, ...entries].map((e) => (
                <span
                    class="px-8 opacity-70 tracking-[0.15em]"
                    style="font-family:'Bebas Neue',sans-serif; font-size:0.85rem;"
                >{e.title} ░</span>
            ))}
        </div>
    </div>

    <script>
        for (const card of Array.from(document.getElementsByClassName("slide-card"))) {
            card.addEventListener("click", () => {
                window.open((card as HTMLElement).dataset.url, "_blank");
            });
        }
        for (const badge of Array.from(document.getElementsByClassName("badge-video"))) {
            badge.addEventListener("click", (e) => {
                window.open((badge as HTMLElement).dataset.url, "_blank");
                e.stopPropagation();
            });
        }
    </script>
</Default>
