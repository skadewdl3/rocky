---
import Default from "../layouts/Default.astro";
---

<Default>
    <style slot="styles">
        /* clamp() — no Tailwind equivalent */
        .hero-title {
            font-size: clamp(5rem, 12vw, 9rem);
            line-height: 0.9;
        }

        /* paint-order stroke — no Tailwind equivalent */
        .hero-title .accent {
            color: #f0e000;
            -webkit-text-stroke: 3px #000;
            paint-order: stroke fill;
        }
        @media (max-width: 480px) {
            .hero-title .accent {
                -webkit-text-stroke: 2px #000;
            }
        }

        /* hover-child selectors on .btn variants */
        .btn-primary:hover {
            background: #f0e000;
            color: #000;
        }
        .btn-secondary:hover {
            background: #000;
            color: #f5f0e8;
        }

        /* ticker keyframe */
        @keyframes ticker {
            from {
                transform: translateX(0);
            }
            to {
                transform: translateX(-50%);
            }
        }
        .ticker-inner {
            display: inline-flex;
            white-space: nowrap;
            animation: ticker 20s linear infinite;
        }
    </style>

    <main
        class="grid grid-rows-[auto_1fr_auto] border-b-4 border-black"
        style="min-height:calc(100vh - 8rem);"
    >
        <!-- TOP BAR -->
        <div
            class="flex items-center justify-between bg-black text-[#f0e000] border-b-4 border-black px-5 py-[0.55rem]"
        >
            <span
                class="text-[0.65rem] tracking-[0.15em] uppercase opacity-75"
                style="font-family:'Space Mono',monospace;"
            >
                An experiment for the VIT OSS Systems Community
            </span>
        </div>

        <!-- BODY -->
        <div
            class="grid grid-cols-1 sm:grid-cols-[1fr_220px] border-b-4 border-black"
        >
            <!-- LEFT -->
            <div
                class="flex flex-col justify-center gap-8 px-6 py-10 sm:px-14 sm:py-16 bg-[#f5f0e8] border-b-4 sm:border-b-0 sm:border-r-4 border-black"
            >
                <!-- Eyebrow -->
                <div class="flex items-center gap-3">
                    <span class="w-9 h-1 bg-black shrink-0 block"></span>
                    <span
                        class="text-[0.65rem] tracking-[0.2em] uppercase opacity-55"
                        style="font-family:'Space Mono',monospace;"
                    >
                        Open Source · JIT Compiler
                    </span>
                </div>

                <!-- Title -->
                <h1
                    class="hero-title font-normal tracking-[0.04em] text-black m-0"
                    style="font-family:'Bebas Neue',sans-serif;"
                >
                    ROC<span class="accent">KY</span>
                </h1>

                <!-- Tagline -->
                <p
                    class="m-0 text-[0.8rem] leading-[1.75] opacity-65 max-w-[48ch] border-l-4 border-black pl-5"
                    style="font-family:'Space Mono',monospace;"
                >
                    A LLVM ORCJIT-based JIT compiler built together — open,
                    transparent, and documented from first principles.
                </p>

                <!-- CTA -->
                <div class="flex mt-4">
                    <a
                        href="/docs"
                        class="btn-primary inline-flex items-center gap-2 px-8 py-[0.8rem] border-4 border-black no-underline bg-black text-[#f0e000] transition-colors duration-[120ms] -mr-1"
                        style="font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:0.1em;"
                        >Read Docs →</a
                    >
                    <a
                        href="/slides"
                        class="btn-secondary inline-flex items-center gap-2 px-8 py-[0.8rem] border-4 border-black no-underline bg-[#f5f0e8] text-black transition-colors duration-[120ms]"
                        style="font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:0.1em;"
                        >View Slides ░</a
                    >
                </div>
            </div>

            <!-- RIGHT SIDEBAR (hidden on mobile) -->
            <div class="hidden sm:flex flex-col bg-[#f5f0e8]">
                <div
                    class="flex flex-col gap-[0.35rem] flex-1 p-5 border-b-4 border-black"
                >
                    <span
                        class="text-[0.58rem] tracking-[0.18em] uppercase opacity-45"
                        style="font-family:'Space Mono',monospace;">Type</span
                    >
                    <span
                        class="text-[2.2rem] leading-none tracking-[0.05em]"
                        style="font-family:'Bebas Neue',sans-serif;">JIT</span
                    >
                    <span
                        class="text-[0.6rem] leading-[1.5] opacity-45"
                        style="font-family:'Space Mono',monospace;"
                        >Just-In-Time<br />Compiler</span
                    >
                </div>
                <div
                    class="flex flex-col gap-[0.35rem] flex-1 p-5 border-b-4 border-black"
                >
                    <span
                        class="text-[0.58rem] tracking-[0.18em] uppercase opacity-45"
                        style="font-family:'Space Mono',monospace;">Built</span
                    >
                    <span
                        class="text-[2.2rem] leading-none tracking-[0.05em]"
                        style="font-family:'Bebas Neue',sans-serif;">Open</span
                    >
                    <span
                        class="text-[0.6rem] leading-[1.5] opacity-45"
                        style="font-family:'Space Mono',monospace;"
                        >Source-first<br />development</span
                    >
                </div>
                <div class="flex flex-col gap-[0.35rem] flex-1 p-5">
                    <span
                        class="text-[0.58rem] tracking-[0.18em] uppercase opacity-45"
                        style="font-family:'Space Mono',monospace;"
                        >License</span
                    >
                    <span
                        class="text-[2.2rem] leading-none tracking-[0.05em]"
                        style="font-family:'Bebas Neue',sans-serif;">MIT</span
                    >
                    <span
                        class="text-[0.6rem] leading-[1.5] opacity-45"
                        style="font-family:'Space Mono',monospace;"
                        >Free to use<br />&amp; modify</span
                    >
                </div>
            </div>
        </div>

        <!-- BOTTOM BAR -->
        <div class="grid grid-cols-1 sm:grid-cols-3 bg-black text-[#f5f0e8]">
            <div
                class="flex items-center px-6 py-4 text-[0.62rem] tracking-[0.12em] uppercase opacity-50 border-b-2 sm:border-b-0 sm:border-r-4 border-[#f5f0e8]"
                style="font-family:'Space Mono',monospace;"
            >
                LLVM OrcJIT backend
            </div>
            <div
                class="flex items-center px-6 py-4 text-[0.62rem] tracking-[0.12em] uppercase opacity-50 border-b-2 sm:border-b-0 sm:border-r-4 border-[#f5f0e8]"
                style="font-family:'Space Mono',monospace;"
            >
                Built in public
            </div>
            <div
                class="flex items-center px-6 py-4 text-[0.62rem] tracking-[0.12em] uppercase opacity-50"
                style="font-family:'Space Mono',monospace;"
            >
                VIT OSS Systems Community
            </div>
        </div>
    </main>
</Default>
